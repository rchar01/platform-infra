proxmox_endpoint       = "https://192.0.2.10:8006/api2/json"
proxmox_api_token_file = "~/.config/platform-infrastructure/infra/proxmox.token"
proxmox_insecure       = false
proxmox_node           = "pve"

default_bridge               = "vmbr0"
default_datastore            = "local-lvm"
default_cloud_init_datastore = "local-lvm"
default_scsi_hardware        = "virtio-scsi-single"
default_disk_iothread        = true
default_disk_discard         = "on"
default_disk_cache           = "none"
default_disk_file_format     = "raw"
default_dns_servers          = ["192.0.2.1"]
default_dns_search_domain    = "example.test"
template_vm_id               = 9001

# Per-VM cloud-init SSH keys are generated by make init-ssh.
cloud_init_username = "rocky"
agent_enabled       = true
default_agent_trim  = false

vms = {
  example-dev-bastion-01 = {
    vm_id       = 102
    hostname    = "example-dev-bastion-01.example.test"
    description = "Example dev bastion VM"
    tags        = ["rocky", "bastion", "dev"]

    cores              = 2
    cpu_type           = "host"
    memory_mb          = 4096
    memory_floating_mb = 2867
    disk_gb            = 25

    additional_disks = [
      {
        interface = "scsi1"
        size_gb   = 15
      }
    ]

    ipv4         = "192.0.2.60/24"
    ipv4_gateway = "192.0.2.1"
  }

  example-dev-registry-01 = {
    vm_id       = 103
    hostname    = "example-dev-registry-01.example.test"
    description = "Example dev registry VM"
    tags        = ["rocky", "dev", "registry"]

    cores              = 2
    cpu_type           = "host"
    memory_mb          = 4096
    memory_floating_mb = 2867
    disk_gb            = 25

    additional_disks = [
      {
        interface = "scsi1"
        size_gb   = 25
      }
    ]

    ipv4         = "192.0.2.61/24"
    ipv4_gateway = "192.0.2.1"
  }

  example-dev-registry-runner-01 = {
    vm_id       = 104
    hostname    = "example-dev-registry-runner-01.example.test"
    description = "Example dev registry runner VM"
    tags        = ["rocky", "dev", "registry", "runner"]

    cores              = 2
    cpu_type           = "host"
    memory_mb          = 4096
    memory_floating_mb = 2867
    disk_gb            = 25

